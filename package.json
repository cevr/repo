{
  "name": "@cvr/repo",
  "version": "1.2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/cevr/repo.git"
  },
  "bin": {
    "repo": "./bin/repo"
  },
  "files": [
    "src",
    "tsconfig.json"
  ],
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "bun build src/main.ts --outfile bin/repo --compile",
    "postinstall": "bun run build",
    "dev": "bun run src/main.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "gate": "concurrently -n type,lint,fmt,test,build -c blue,yellow,magenta,green,cyan \"bun run typecheck\" \"bun run lint:fix\" \"bun run fmt\" \"bun run test\" \"bun run build\"",
    "prepare": "lefthook install || true && effect-language-service patch",
    "link": "ln -sf $(pwd)/bin/repo ~/.bun/bin/repo",
    "version": "changeset version",
    "release": "changeset publish"
  },
  "dependencies": {
    "@effect/platform-bun": "4.0.0-beta.31",
    "effect": "4.0.0-beta.31"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@effect/language-service": "^0.80.0",
    "@types/bun": "^1.3.10",
    "concurrently": "^9.2.1",
    "effect-bun-test": "^0.2.1",
    "lefthook": "^2.1.4",
    "oxfmt": "^0.39.0",
    "oxlint": "^1.54.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "bun": ">=1.0.0"
  }
}
